{
  "manifest_version": 3,
  "name": "Vodia PBX Admin Sidebar",
  "version": "1.0.0",
  "description": "Admin sidebar for Vodia PBX — account overview per tenant with tabbed notes and export/import.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://localhost/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "all_frames": false,
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": ["convention.json"],
      "matches": ["https://*/*", "http://localhost/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
